# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=mongodb_mastra_qs
ALLOW_INSECURE=false                 # set true only to permit a non-TLS mongodb:// URI (local dev)
MONGO_MAX_POOL_SIZE=100              # max pooled connections per runtime MongoClient (tune for concurrency at scale)
MONGO_MIN_POOL_SIZE=10               # warm connections kept open to reduce cold-start latency

# --- Voyage (embeddings + rerank) ---
VOYAGE_API_KEY=                      # a MongoDB Atlas Voyage key works against the MongoDB-hosted endpoint below; a native Voyage key needs VOYAGE_BASE_URL cleared
VOYAGE_BASE_URL=https://ai.mongodb.com/v1   # MongoDB-hosted Voyage endpoint (Bearer auth). Clear to use native api.voyageai.com with a native Voyage key.
MEMORY_EMBED_MODEL=voyage-3.5       # text embedder for Mastra semantic recall (1024-dim, on the same MongoDB Voyage endpoint)

# --- LLM (gateway routing via LLM_BASE_URL applies to the LLM only) ---
LLM_PROVIDER=anthropic               # anthropic | openai | bedrock
LLM_MODEL=claude-sonnet-4-6          # demo default: balanced reliability + latency. haiku-4-5 = faster/cheaper, opus-4-8 = deepest.
LLM_BASE_URL=                        # optional gateway base URL for the LLM (Anthropic API root, e.g. .../anthropic/v1; a trailing /messages is stripped)
GROVE_API_KEY=                       # gateway key; sent as the `api-key` header when LLM_BASE_URL points at an APIM gateway
# AWS Bedrock (LLM_PROVIDER=bedrock): LLM_MODEL must be a cross-region INFERENCE-PROFILE id,
# e.g. us.anthropic.claude-sonnet-4-5-20250929-v1:0 (NOT the plain claude-sonnet-4-6 id).
# Auth is the AWS default credential chain (EC2 instance role in the deploy) — no API key.
BEDROCK_REGION=                      # optional; else the AWS SDK reads AWS_REGION from the env

# --- Response cache (semantic, served only on a conversation's FIRST message) ---
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_TTL_DAYS=1
RESPONSE_CACHE_SIMILARITY_THRESHOLD=0.92
RESPONSE_CACHE_MAX_ANSWER_BYTES=32768

# --- Memory recall (latency) ---
# MEMORY_SEMANTIC_RECALL toggles the per-turn cross-thread vector search Mastra runs on
# EVERY message (an embed + Atlas $vectorSearch over the user's whole history). It adds
# ~10s to even a "hi", so it defaults OFF. Cross-thread personalization is carried by
# working memory (the shopper profile), which stays on regardless. Turn on only if you
# want the agent to recall arbitrary past messages semantically and accept the latency.
MEMORY_SEMANTIC_RECALL=false
# Cheap in-thread coherence: how many recent messages of the CURRENT thread to load
# (a storage read, no embedding). 0/false disables conversation history entirely.
MEMORY_LAST_MESSAGES=10

# --- Retrieval / tools ---
RRF_K=60
DATA_AGENT_ALLOW_LIST=products,orders,promotions
DATA_AGENT_LIMIT=25

# --- Server / demo ---
PORT=8000
DEFAULT_USER_ID=demo
# Auth mode. 'local' (default) has NO login: the client-supplied user_id is trusted so you
# can switch users to demo cross-thread memory. This is NOT secure — do not expose a 'local'
# deployment publicly. 'sso' requires a registered auth adapter (AUTH_ADAPTER_MODULE),
# ignores client-supplied identity, and rejects unauthenticated requests (401).
AUTH_MODE=local
# Path to the deployment's auth adapter module (only used when AUTH_MODE=sso). Provided at
# deploy time by the hosting platform's SSO integration and NOT part of this repo. It must
# export `register(register, cfg)` and call register(fn) with an authenticator. Defaults to ./auth-adapter.
AUTH_ADAPTER_MODULE=
EMIT_PLAN_FRAMES=false               # true for the stage build
INGEST_DESCRIBE=true                 # Milestone 2 ingestion knob
INGEST_PDF_SCALE=2.0                 # rasterization resolution for PDF page-render ingestion
INGEST_ASSETS_DIR=                   # override the committed src/ingestion/assets dir (absolute path); default uses the bundled assets
PREWARM_QUERIES=                     # optional pipe-separated demo queries to pre-warm the cache; defaults to a built-in set
